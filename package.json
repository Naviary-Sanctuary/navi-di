{
  "name": "es-di",
  "version": "0.1.0",
  "description": "Dependency injection for standard ECMAScript decorators.",
  "keywords": [
    "bun",
    "decorators",
    "dependency-injection",
    "di",
    "ecmascript",
    "node",
    "typescript"
  ],
  "homepage": "https://github.com/Naviary-Sanctuary/es-di#readme",
  "bugs": {
    "url": "https://github.com/Naviary-Sanctuary/es-di/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Naviary-Sanctuary/es-di.git"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "CODE_OF_CONDUCT.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json",
    "hooks:install": "lefthook install",
    "hooks:validate": "lefthook validate",
    "hooks:run:pre-commit": "lefthook run pre-commit --all-files --force",
    "lint": "oxlint . --deny-warnings",
    "fmt": "oxfmt --config .oxfmt.json .",
    "fmt:check": "oxfmt --check --config .oxfmt.json .",
    "postinstall": "lefthook install",
    "prepack": "bun run lint && bun run fmt:check && bun run typecheck && bun run build",
    "test": "bun test --pass-with-no-tests"
  },
  "devDependencies": {
    "@types/bun": "1.3.11",
    "lefthook": "^2.1.4",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=18.18"
  },
  "packageManager": "bun@1.3.10"
}
